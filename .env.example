# ============================================================
# agentflow-platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ============================================================
# REQUIRED
# ============================================================

# Strong random password for PostgreSQL
POSTGRES_PASSWORD=change_this_strong_password

# OpenAI API key (required if any agent uses provider=openai)
OPENAI_API_KEY=sk-...

# Fernet symmetric encryption key for per-agent API keys stored in DB.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ============================================================
# OPTIONAL LLM PROVIDERS
# ============================================================

# Anthropic Claude models
ANTHROPIC_API_KEY=

# Google Gemini models
GOOGLE_API_KEY=

# ============================================================
# PRODUCTION (Coolify deployment)
# ============================================================

# Public-facing domain as full URL  e.g. https://agents.example.com
DOMAIN=https://yourdomain.com

# WebSocket domain — replace https:// with wss://
DOMAIN_WS=wss://yourdomain.com

# Application environment: development | production
APP_ENV=production

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Gunicorn worker count — recommended: (2 × CPU cores) + 1
WORKERS=4

# ============================================================
# OPTIONAL — LangSmith observability (LangChain tracing)
# ============================================================
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=agentflow
